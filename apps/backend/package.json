{
  "name": "self-checkout-backend",
  "version": "1.0.0",
  "description": "Backend del sistema de autopago",
  "scripts": {
    "build": "tsc",
    "build:socket": "tsc -p tsconfig.socket.json",
    "dev:socket": "ts-node-dev --respawn --transpile-only src/socket/index.ts",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint src --ext .ts",
    "test": "echo \"No tests yet\"",
    "migration:run": "echo 'No migrations configured - implementar con TypeORM/Prisma cuando corresponda'",
    "seed": "echo 'No seed configurado - implementar cuando corresponda'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
