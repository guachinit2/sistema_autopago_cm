# apps/backend/Dockerfile.socket
FROM node:20-alpine AS base

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build:socket

# Desarrollo: hot-reload con volúmenes
FROM base AS development
EXPOSE 3002
CMD ["npm", "run", "dev:socket"]

# Producción: solo runtime
FROM node:20-alpine AS production
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY --from=base /app/dist/socket ./socket
EXPOSE 3002
CMD ["node", "socket/index.js"]
