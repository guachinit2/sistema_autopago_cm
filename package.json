{
  "name": "self-checkout-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint . --ext .ts,.tsx -c config/eslint.config.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx -c config/eslint.config.cjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --config config/prettier.json --ignore-path config/prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --config config/prettier.json --ignore-path config/prettierignore",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^1.13.0"
  },
  "dependencies": {
    "html5-qrcode": "^2.3.8"
  }
}
